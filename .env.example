# ─── Discord Bot Configuration ────────────────────────────────────────────────
# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# The Discord channel ID where alerts will be posted
# Right-click the channel in Discord > Copy Channel ID (enable Developer Mode first)
CHANNEL_ID=123456789012345678

# ─── Optional Settings ────────────────────────────────────────────────────────
# How often to poll MLB APIs for new challenges (in seconds, default: 30)
POLL_INTERVAL=30

# Log verbosity: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
